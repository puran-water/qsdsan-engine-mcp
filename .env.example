# QSDsan Engine MCP - Environment Configuration
#
# Copy this file to .env and customize for your environment.
# For Cloud Run deployment, set these as Cloud Run environment variables.

# =============================================================================
# Environment Detection
# =============================================================================
# Override auto-detection. Options: local_dev, local_docker, cloud_run
# If not set, environment is auto-detected.
# QSDSAN_ENV=local_dev

# =============================================================================
# Storage Configuration
# =============================================================================
# Local jobs directory (for LOCAL_DEV and LOCAL_DOCKER)
QSDSAN_JOBS_DIR=./jobs

# Google Cloud Storage bucket (required for CLOUD_RUN)
# QSDSAN_GCS_BUCKET=my-qsdsan-bucket

# GCS path prefix (optional, for organizing files in bucket)
# QSDSAN_GCS_PREFIX=qsdsan-engine/

# Signed URL expiration in minutes (default: 60)
# QSDSAN_SIGNED_URL_EXPIRY=60

# =============================================================================
# Server Configuration
# =============================================================================
# Maximum concurrent background jobs (default: 3)
QSDSAN_MAX_JOBS=3

# Default job timeout in seconds (optional, no default timeout)
# QSDSAN_DEFAULT_TIMEOUT=3600

# Enable debug logging
QSDSAN_DEBUG=false

# =============================================================================
# Google Cloud Configuration (for CLOUD_RUN only)
# =============================================================================
# These are typically set automatically by Cloud Run
# GOOGLE_CLOUD_PROJECT=my-project-id
# K_SERVICE=qsdsan-engine-mcp

# =============================================================================
# AI Analysis Configuration (Optional)
# =============================================================================
# OpenAI API key for AI-powered simulation analysis
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-api-key-here

# Default model for analysis (optional, defaults to gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_MODEL=gpt-4o
