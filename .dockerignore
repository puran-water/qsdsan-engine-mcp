# QSDsan Engine MCP - Docker Build Exclusions

# Git
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.eggs
*.egg
.mypy_cache
.pytest_cache
.coverage
htmlcov

# Virtual environments
venv
.venv
env
.env.local

# IDE
.vscode
.idea
*.swp
*.swo

# Documentation (not needed in container)
docs/
*.md
!README.md

# Tests (not needed in production container)
tests/
pytest.ini

# Jobs directory (will be mounted as volume)
jobs/

# Claude/AI artifacts
.claude/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log
